{
  "liveServer.settings.ignoreFiles": [
    "**/.vscode/**",
    "**/.git/**",
    "**/.DS_Store",
    "**/node_modules/**",
    "**/venv/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "**/db.sqlite3",
    "**/*.sqlite3"
  ],
  "liveServer.settings.port": 8000,
  "liveServer.settings.wait": 2000
}
